# LINE channel credentials (required)
LINE_CHANNEL_SECRET=
LINE_CHANNEL_ACCESS_TOKEN=

# Optional overrides
LINE_API_BASE=https://api.line.me
PORT=8080

# Push master toggle. Default OFF — when false, LinePushClient.push/multicast log
# the outbound payload and return without calling LINE. Flip to true to actually send.
LINE_PUSH_ENABLED=false

# MySQL (shared with Python news-collector). Default OFF — when false, the
# MarketAnalysisPoller, repositories, and /admin endpoints are not registered.
LINE_RELAY_MYSQL_ENABLED=false
LINE_RELAY_MYSQL_URL=jdbc:mysql://localhost:3306/news_relay?useSSL=false&serverTimezone=UTC&characterEncoding=utf8mb4
LINE_RELAY_MYSQL_USER=
LINE_RELAY_MYSQL_PASSWORD=
LINE_RELAY_MYSQL_CONNECT_TIMEOUT_MS=5000

# Table names (override only if your schema uses different names)
LINE_RELAY_MYSQL_ANALYSIS_TABLE=t_market_analyses
LINE_RELAY_MYSQL_GROUP_TABLE=t_bot_group_info
LINE_RELAY_MYSQL_USER_TABLE=t_bot_user_info
